### ─── AUTH ───────────────────────────────────────────────────────────────────

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "test@challenge.fr",
  "password": "password123",
  "display_name": "Test User"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test@challenge.fr",
  "password": "password123"
}

### Refresh token
POST {{baseUrl}}/auth/refresh
Cookie: refreshToken={{refreshToken}}

### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{accessToken}}

### ─── USERS ───────────────────────────────────────────────────────────────────

### Get all users
GET {{baseUrl}}/users
Authorization: Bearer {{accessToken}}

### Get user by id
GET {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{accessToken}}

### Update user
PATCH {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "display_name": "New Name"
}

### Delete user
DELETE {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{accessToken}}

### ─── PROJECTS ────────────────────────────────────────────────────────────────

### Create project
POST {{baseUrl}}/projects
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Mon Projet Challenge"
}

### List my projects
GET {{baseUrl}}/projects
Authorization: Bearer {{accessToken}}

### Get project by id
GET {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{accessToken}}

### Update project
PATCH {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Nouveau Nom"
}

### Delete project
DELETE {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{accessToken}}

### Add member to project
POST {{baseUrl}}/projects/{{projectId}}/members
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "userId": "USER_UUID_HERE",
  "role": "member"
}

### Remove member from project
DELETE {{baseUrl}}/projects/{{projectId}}/members/{{userId}}
Authorization: Bearer {{accessToken}}

### ─── TASKS ───────────────────────────────────────────────────────────────────

### Create task
POST {{baseUrl}}/projects/{{projectId}}/tasks
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Implémenter le serveur MCP",
  "description": "Créer les tools list_projects, list_tasks, create_task...",
  "status_id": "{{todoStatusId}}",
  "priority": "high",
  "deadline": "2026-03-31T23:59:00Z"
}

### List tasks (all)
GET {{baseUrl}}/projects/{{projectId}}/tasks
Authorization: Bearer {{accessToken}}

### List tasks (filtered by status)
GET {{baseUrl}}/projects/{{projectId}}/tasks?status_id={{todoStatusId}}
Authorization: Bearer {{accessToken}}

### List tasks (filtered by assignee)
GET {{baseUrl}}/projects/{{projectId}}/tasks?assignee_id={{userId}}
Authorization: Bearer {{accessToken}}

### List overdue tasks
GET {{baseUrl}}/projects/{{projectId}}/tasks?overdue=true
Authorization: Bearer {{accessToken}}

### Get task by id
GET {{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}
Authorization: Bearer {{accessToken}}

### Update task (change status → Done)
PATCH {{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status_id": "{{doneStatusId}}"
}

### Update task (assign + deadline)
PATCH {{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "assignee_id": "USER_UUID_HERE",
  "deadline": "2026-04-01T12:00:00Z",
  "priority": "medium"
}

### Delete task
DELETE {{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}
Authorization: Bearer {{accessToken}}
